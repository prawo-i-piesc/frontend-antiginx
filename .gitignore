# ------------------------------------------
# .gitignore for Next.js projects
# -------------------------------------------

# ------------------------------------------
# Dependencies
# ------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions


# ------------------------------------------
# Testing
# ------------------------------------------
/coverage


# ------------------------------------------
# Next.js
# ------------------------------------------
/.next/
/out/


# ------------------------------------------
# Production
# ------------------------------------------
/build


# ------------------------------------------
# Debug
# ------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ------------------------------------------
# Vercel
# ------------------------------------------
.vercel


# ------------------------------------------
# TypeScript
# ------------------------------------------
*.tsbuildinfo
next-env.d.ts


# ------------------------------------------
# Local env files
# ------------------------------------------
.env
.env*.local
.env.development
.env.test
.env.production.local


# ------------------------------------------
# Other files and directories to ignore
# ------------------------------------------


# ------------------------------------------
# System Files and OS Artifacts
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.Trash/
.CFUserTextEncoding
.DocumentRevisions-V100
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.cab
*.lnk
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*
.fuse_hidden*
.Xauthority


# ------------------------------------------
# Code Editor and IDE Files
# ------------------------------------------
# Vim
*.swp
*.swo
.netrwhist
*~

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/keybindings.json

# JetBrains
.idea/
*.iml


# ------------------------------------------
# Temporary and Backup Files
# ------------------------------------------
*.bak
*.tmp
*.temp
*.dockerfile.bak


# ------------------------------------------
# Archive and Compressed Files
# ------------------------------------------
*.7z
*.bz2
*.bzip
*.bzip2
*.gz
*.gzip
*.jar
*.lzma
*.rar
*.tar.gz
*.tgz
*.xar
*.xz
*.zip
*.iso
*.dmg
*.deb
*.egg
*.gem
*.msi
*.msm
*.msp
*.rpm
*.txz
*.xpi


# ------------------------------------------
# Security-Sensitive Files and Credentials
# ------------------------------------------
.ssh/*
.gnupg/
.aws/
.azure/
.kube/config
*.pem
*.key
.netrc
.npmrc
.env
.env.*
!.env.example
.docker/config.json
.gcloud/
.config/gh/
*.p12
*.pfx